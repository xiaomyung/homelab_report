# homelab_report — Telegram credentials
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
#
# How to get these values:
#   TG_BOT_TOKEN: message @BotFather on Telegram → /newbot → copy the token
#   TG_CHAT_ID:   message @userinfobot or send a message to your bot, then call:
#                 https://api.telegram.org/bot<TOKEN>/getUpdates
#                 and look for "chat": {"id": ...}

TG_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TG_CHAT_ID=123456789
